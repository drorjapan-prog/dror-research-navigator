{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "name",
    "version",
    "studies"
  ],
  "properties": {
    "studies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "authors",
          "year",
          "title",
          "journal",
          "type",
          "status",
          "population",
          "sample",
          "method",
          "finding",
          "limitations",
          "source_url"
        ],
        "properties": {
          "limitations": {
            "type": "array",
            "minItems": 1
          }
        }
      }
    }
  }
}